{
  "name": "delivery-docs-app",
  "version": "1.0.0",
  "description": "Delivery Documentation App for GeoTower",
  "private": true,
  "engines": {
    "node": "18.x",
    "npm": "9.x"
  },
  "scripts": {
    "setup": "echo 'Instalando dependências...' && cd backend && npm install && cd ../frontend && npm install && echo '✓ Setup completo!'",
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\"",
    "dev:backend": "cd backend && npm run dev",
    "dev:frontend": "cd frontend && npm start",
    "build:frontend": "cd frontend && npm install && npm run build",
    "start": "node start.js",
    "clean": "node scripts/clean.js"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  },
  "dependencies": {
    "axios": "^1.15.2",
    "browser-image-compression": "^2.0.2",
    "chokidar": "^5.0.0",
    "csv-parse": "^6.2.1",
    "csv-parser": "^3.2.0",
    "dotenv": "^17.4.0",
    "framer-motion": "^12.38.0",
    "googleapis": "^118.0.0",
    "html-docx-js": "^0.3.1",
    "html-pdf": "^3.0.1",
    "html2canvas": "^1.4.1",
    "imap-simple": "^5.1.0",
    "jspdf": "^4.2.0",
    "jspdf-autotable": "^5.0.7",
    "lucide-react": "^1.8.0",
    "mailparser": "^3.9.3",
    "markdown-it": "^14.1.1",
    "markdown-pdf": "^11.0.0",
    "mongodb": "^7.1.1",
    "mongoose": "^9.4.1",
    "puppeteer": "^24.37.5",
    "xlsx": "^0.18.5"
  }
}
